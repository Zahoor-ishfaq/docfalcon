# LLM
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
LLM_PROVIDER=claude                          # claude | groq

# Database
MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/docfalcon

# Cache
REDIS_URL=https://your-instance.upstash.io
REDIS_TOKEN=your-upstash-token

# Auth
JWT_SECRET=change-me-to-32-plus-random-chars
JWT_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OCR
GOOGLE_APPLICATION_CREDENTIALS=./google-vision-key.json
POPPLER_PATH=C:\Program Files\poppler-26.02.0\Library\bin   # Windows only

# RAG
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
VECTOR_INDEX_NAME=chunks_vector_index

# Tracing
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# App
ENVIRONMENT=development                      # development | production
ALLOWED_ORIGINS=http://localhost:5173        # comma-separated in prod